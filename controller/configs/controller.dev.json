{
  "controller_id": "controller-01",
  "listen_addr": ":9091",
  "state_file": "data/state.json",
  "http_timeout_seconds": 10,
  "sync_interval_sec": 30,
  "master": {
    "base_url": "http://127.0.0.1:8080",
    "port": 8080,
    "bootstrap_path": "/controller/auth/bootstrap",
    "rotate_path": "/controller/auth/rotate",
    "controllers_path": "/controller/controllers",
    "pair_path": "/controller/pair",
    "update_ack_path": "/controller/update/ack",
    "update_apply_path": "/controller/update/apply",
    "shared_token": "replace-with-controller-shared-token"
  },
  "slave": {
    "default_port": 8080
  }
}
